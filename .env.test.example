# Test Configuration
# Copy this file to .env.test and fill in your actual values
# .env.test is gitignored and will never be committed

# Primary test account
TEST_ACCOUNT_1=your-email@fastmail.com
TEST_TOKEN_1=fmu1-your-api-token-here

# Secondary test account (optional, for multi-account tests)
TEST_ACCOUNT_2=second-email@fastmail.com
TEST_TOKEN_2=fmu1-second-api-token-here

# Recipient for send/forward tests
TEST_RECIPIENT=test-recipient@example.com

# CalDAV Testing (requires app password, not API token)
# Create an app password in Fastmail Settings → Privacy & Security → Integrations
TEST_CALDAV_USERNAME=your-email@fastmail.com
TEST_CALDAV_PASSWORD=your-app-password-here
