{
    "name": "fastmail-courier",
    "version": "1.0.0",
    "description": "MCP server for Fastmail email integration via JMAP",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "fastmail-mcp": "dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src --ext .ts",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "mcp",
        "fastmail",
        "jmap",
        "email",
        "claude",
        "gemini"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "express": "^4.21.2",
        "jmap-courier": "file:../jmap-courier",
        "jose": "^5.9.3",
        "tsdav": "^2.1.6",
        "zod": "^3.23.0",
        "zod-to-json-schema": "^3.23.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^22.0.0",
        "dotenv": "^16.4.0",
        "typescript": "^5.6.0",
        "vitest": "^2.1.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
